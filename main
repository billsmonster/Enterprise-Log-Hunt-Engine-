#!/usr/bin/env python3
"""
ELHE — Enterprise Log Hunt Engine (Enterprise-ish, Portfolio Single-File)
========================================================================

This single-file tool is meant to look and feel like a real hunting utility:
- Parse Windows EVTX logs (Security + Sysmon Operational)
- Normalize events into a common schema
- Enrich events (offline) with quick context (IP type, URLs, base64 hints)
- Run detections (rules) for:
    * Lateral movement
    * Privilege escalation
    * Living-off-the-land (LOLBin) activity
- Optional baseline/anomaly mode: highlight "NEW source IP for this user"
- Simple process-chain correlation heuristic (Office -> script/LOLBin)

It runs with ZERO args (auto-discovers common EVTX paths on Windows),
and also supports explicit CLI arguments.

Optional dependencies:
  pip install python-evtx tqdm pyyaml

Exit codes:
  0 OK
  1 Dependency missing (e.g., python-evtx for EVTX)
  2 No logs found / provided
  3 Fatal processing error
"""

from __future__ import annotations

# Standard library imports
import argparse
import csv
import dataclasses
import datetime as dt
import ipaddress
import json
import logging
import os
import re
import sys
from collections import Counter, defaultdict, deque
from pathlib import Path
from typing import Any, Callable, Deque, Dict, Iterable, List, Optional, Sequence, Tuple


# =============================================================================
# Exit codes (professional touch)
# =============================================================================
# These make automation / scripting nicer (CI jobs, scheduled tasks, etc.)
EXIT_OK = 0
EXIT_DEP_MISSING = 1
EXIT_NO_LOGS = 2
EXIT_FATAL = 3


# =============================================================================
# Logger setup
# =============================================================================
# Using a named logger allows controlled verbosity and easier integration.
log = logging.getLogger("elhe")


def setup_logging(verbose: bool, quiet: bool) -> None:
    """
    Configure log level + format based on CLI flags.
    """
    if quiet:
        level = logging.ERROR
    elif verbose:
        level = logging.DEBUG
    else:
        level = logging.INFO

    logging.basicConfig(
        level=level,
        format="%(asctime)s [%(levelname)s] %(message)s",
    )


# =============================================================================
# Optional dependencies
# =============================================================================
# We keep the tool usable even when optional deps are missing.
# - python-evtx is REQUIRED to parse EVTX logs
# - tqdm is OPTIONAL for progress bars
# - pyyaml is OPTIONAL for config files (yaml)
EVTX_AVAILABLE = False
ET = None

try:
    # python-evtx provides the EVTX class for reading Windows event logs
    from Evtx.Evtx import Evtx  # type: ignore

    # xml.etree handles the XML inside each EVTX record
    import xml.etree.ElementTree as _ET

    ET = _ET
    EVTX_AVAILABLE = True
except Exception:
    EVTX_AVAILABLE = False
    ET = None

TQDM_AVAILABLE = False
tqdm = None
try:
    from tqdm import tqdm as _tqdm  # type: ignore

    tqdm = _tqdm
    TQDM_AVAILABLE = True
except Exception:
    TQDM_AVAILABLE = False
    tqdm = None

YAML_AVAILABLE = False
yaml = None
try:
    import yaml as _yaml  # type: ignore

    yaml = _yaml
    YAML_AVAILABLE = True
except Exception:
    YAML_AVAILABLE = False
    yaml = None


# =============================================================================
# Normalized Event Model
# =============================================================================
# This dataclass is the backbone of the tool:
# it maps wildly different logs into one unified schema so rules can be simple.
@dataclasses.dataclass
class NormEvent:
    # Raw timestamp string (usually ISO) as it appears in the log
    ts: str

    # Parsed timestamp (timezone-aware UTC) if we could parse it, else None
    dt: Optional[dt.datetime]

    # High-level source label: "windows_evtx" or "sysmon"
    source: str = "windows_evtx"

    # Host/device that generated the event (Computer field)
    host: str = ""

    # Windows "Channel" (Security, Sysmon Operational, etc.)
    channel: str = ""

    # Provider name (e.g., Microsoft-Windows-Security-Auditing)
    provider: str = ""

    # Event ID (e.g., 4624, 4672, 7045, Sysmon 1, etc.)
    event_id: str = ""

    # User context (TargetUserName, SubjectUserName, etc.)
    user: str = ""

    # Network context (best-effort)
    src_ip: str = ""
    src_port: str = ""
    dst_ip: str = ""
    dst_port: str = ""

    # Process context (best-effort)
    process: str = ""
    cmdline: str = ""
    parent_process: str = ""

    # A short "action" label derived from event_id
    action: str = ""

    # extras holds parsed or enriched fields that rules often want
    extras: Dict[str, Any] = dataclasses.field(default_factory=dict)

    # raw holds the parsed XML dict (System + EventData), useful for deep inspection
    raw: Dict[str, Any] = dataclasses.field(default_factory=dict)


# =============================================================================
# String + time helpers
# =============================================================================
def iso_now() -> str:
    """
    Create an ISO UTC timestamp string (used as a fallback).
    """
    return dt.datetime.utcnow().replace(microsecond=0).isoformat() + "Z"


def lower(s: str) -> str:
    """
    Safe lowercase helper (handles None).
    """
    return (s or "").lower()


def safe_str(x: Any) -> str:
    """
    Convert anything to a safe string for normalization.
    """
    if x is None:
        return ""
    return str(x)


def parse_iso_any(ts: str) -> Optional[dt.datetime]:
    """
    Best-effort ISO parsing.

    Why it matters:
    - EVTX SystemTime is often like: 2025-12-12T12:00:00.1234567Z
    - CLI filters use ISO timestamps too.

    Output:
    - timezone-aware UTC datetime when possible
    - None if unparseable (we do NOT drop events just because time parsing fails)
    """
    if not ts:
        return None

    s = ts.strip()

    # Common case: trailing Z means UTC
    if s.endswith("Z"):
        s = s.replace("Z", "+00:00")

    try:
        d = dt.datetime.fromisoformat(s)

        # If naive, treat it as UTC
        if d.tzinfo is None:
            return d.replace(tzinfo=dt.timezone.utc)

        # Otherwise normalize to UTC
        return d.astimezone(dt.timezone.utc)
    except Exception:
        return None


def parse_user_time(s: str) -> Optional[dt.datetime]:
    """
    Parse CLI --since/--until. Returns UTC-aware datetime or None.
    """
    d = parse_iso_any(s)
    if d is None:
        return None
    if d.tzinfo is None:
        d = d.replace(tzinfo=dt.timezone.utc)
    return d.astimezone(dt.timezone.utc)


# =============================================================================
# Offline enrichment
# =============================================================================
# These regex patterns give us quick context for cmdlines without internet access.
URL_RX = re.compile(r"(?i)\bhttps?://[^\s\"']+")
B64_RX = re.compile(r"(?i)\b[A-Za-z0-9+/]{80,}={0,2}\b")  # rough base64 blob heuristic
SUSP_FLAGS = ("-enc", "encodedcommand", "frombase64string", "iex", "iwr", "wget", "curl", "downloadstring")


def is_private_ip(ip: str) -> Optional[bool]:
    """
    Returns:
      True  -> RFC1918 private
      False -> public
      None  -> invalid / missing / loopback sentinel
    """
    ip = (ip or "").strip()
    if not ip or ip in ("-", "::1"):
        return None
    try:
        return ipaddress.ip_address(ip).is_private
    except Exception:
        return None


def enrich_event(e: NormEvent) -> None:
    """
    Add fast, offline enrichment that makes findings more usable:
    - private/public IP
    - URLs extracted from cmdline
    - base64 blob presence
    - suspicious flags
    """
    cmd = e.cmdline or ""
    e.extras["ip_private"] = is_private_ip(e.src_ip)
    e.extras["urls"] = URL_RX.findall(cmd)[:10]
    e.extras["has_base64_blob"] = bool(B64_RX.search(cmd))

    lc = lower(cmd)
    e.extras["susp_flags"] = [f for f in SUSP_FLAGS if f in lc][:10]


# =============================================================================
# EVTX XML parsing
# =============================================================================
def xml_to_dict(xml_text: str) -> Dict[str, Any]:
    """
    Convert a Windows Event XML record into a dict with:
      out["System"]   -> key system fields
      out["EventData"]-> name/value pairs

    Why:
    - Rules want simple access like rec["EventData"]["LogonType"]
    """
    if ET is None:
        return {"System": {}, "EventData": {}}

    try:
        root = ET.fromstring(xml_text)  # type: ignore
    except Exception:
        return {"System": {}, "EventData": {}}

    out: Dict[str, Any] = {"System": {}, "EventData": {}}

    # Parse the <System> section
    sys_node = root.find("./System")
    if sys_node is not None:
        for child in list(sys_node):
            tag = child.tag.split("}")[-1]

            if tag == "TimeCreated":
                out["System"]["TimeCreated"] = child.attrib.get("SystemTime", "")
            elif tag == "Provider":
                out["System"]["Provider"] = child.attrib.get("Name", "")
            elif tag == "EventID":
                out["System"]["EventID"] = (child.text or "").strip()
            elif tag == "Computer":
                out["System"]["Computer"] = (child.text or "").strip()
            elif tag == "Channel":
                out["System"]["Channel"] = (child.text or "").strip()
            else:
                # store other useful fields when present
                if child.text and child.text.strip():
                    out["System"][tag] = child.text.strip()

    # Parse the <EventData> section
    ed = root.find("./EventData")
    if ed is not None:
        for d in list(ed):
            name = d.attrib.get("Name", "")
            if name:
                out["EventData"][name] = (d.text or "").strip()

    return out


def iter_evtx_records(path: str) -> Iterable[Dict[str, Any]]:
    """
    Yield parsed dict records from an EVTX file.

    IMPORTANT:
    - Requires python-evtx
    - We ignore malformed records rather than crashing.
    """
    if not EVTX_AVAILABLE:
        raise ImportError("python-evtx not installed")

    with Evtx(path) as ev:  # type: ignore
        for rec in ev.records():
            try:
                yield xml_to_dict(rec.xml())
            except Exception:
                continue


def normalize_event(rec: Dict[str, Any], source_hint: str = "windows_evtx") -> NormEvent:
    """
    Convert raw EVTX dict into a NormEvent.

    Design goal:
    - Most fields are "best effort" (different logs name fields differently)
    - We preserve rec in .raw for deep dives.
    """
    sysd = rec.get("System", {}) if isinstance(rec.get("System"), dict) else {}
    ed = rec.get("EventData", {}) if isinstance(rec.get("EventData"), dict) else {}

    # Timestamp handling (keep event even if parse fails)
    ts = safe_str(sysd.get("TimeCreated")) or iso_now()
    d = parse_iso_any(ts)

    # Standard Windows fields
    eid = safe_str(sysd.get("EventID")).strip()
    host = safe_str(sysd.get("Computer"))
    provider = safe_str(sysd.get("Provider"))
    channel = safe_str(sysd.get("Channel"))

    # Detect Sysmon vs Security based on channel/provider
    src = source_hint
    if "sysmon" in lower(channel) or "sysmon" in lower(provider):
        src = "sysmon"

    # User: different events use different name fields
    user = safe_str(ed.get("TargetUserName") or ed.get("SubjectUserName") or ed.get("User") or "")

    # Network: again best-effort
    src_ip = safe_str(ed.get("IpAddress") or ed.get("SourceIp") or ed.get("SourceAddress") or "")
    src_port = safe_str(ed.get("IpPort") or ed.get("SourcePort") or "")
    dst_ip = safe_str(ed.get("DestAddress") or ed.get("DestinationIp") or "")
    dst_port = safe_str(ed.get("DestPort") or ed.get("DestinationPort") or "")

    # Process context: Sysmon uses Image/CommandLine; Security uses NewProcessName/CommandLine
    process = safe_str(
        ed.get("Image")
        or ed.get("NewProcessName")
        or ed.get("ProcessName")
        or ed.get("Application")
        or ""
    )
    cmdline = safe_str(ed.get("CommandLine") or "")
    parent = safe_str(ed.get("ParentImage") or ed.get("ParentProcessName") or "")

    # Fields important for detections
    logon_type = safe_str(ed.get("LogonType"))
    auth_pkg = safe_str(ed.get("AuthenticationPackageName") or ed.get("AuthenticationPackage") or "")
    workstation = safe_str(ed.get("WorkstationName") or ed.get("TargetServerName") or "")

    service_name = safe_str(ed.get("ServiceName") or "")
    service_path = safe_str(ed.get("ServiceFileName") or ed.get("ImagePath") or "")

    # Sysmon correlation GUIDs
    proc_guid = safe_str(ed.get("ProcessGuid") or "")
    parent_guid = safe_str(ed.get("ParentProcessGuid") or "")

    # Simple action map to make logic readable
    action_map = {
        "4624": "logon_success",
        "4625": "logon_fail",
        "4634": "logoff",
        "4672": "special_privileges",
        "4688": "process_create_sec",
        "4697": "service_install_sec",
        "7045": "service_install",
        "4648": "explicit_creds",
        "4720": "user_created",
        "4728": "group_add_global",
        "4732": "group_add_local",
        "4756": "group_add_universal",
        # Sysmon
        "1": "process_create_sysmon",
        "3": "network_connect_sysmon",
        "11": "file_create_sysmon",
        "13": "registry_set_sysmon",
    }
    action = action_map.get(eid, "")

    # Build normalized event
    e = NormEvent(
        ts=ts,
        dt=d,
        source=src,
        host=host,
        channel=channel,
        provider=provider,
        event_id=eid,
        user=user,
        src_ip=src_ip,
        src_port=src_port,
        dst_ip=dst_ip,
        dst_port=dst_port,
        process=process,
        cmdline=cmdline,
        parent_process=parent,
        action=action,
        extras={
            "LogonType": logon_type,
            "AuthPackage": auth_pkg,
            "WorkstationName": workstation,
            "ServiceName": service_name,
            "ServicePath": service_path,
            "ProcessGuid": proc_guid,
            "ParentProcessGuid": parent_guid,
        },
        raw=rec,
    )

    # Add offline enrichment
    enrich_event(e)
    return e


# =============================================================================
# Rule metadata + match functions (pickle-safe)
# =============================================================================
@dataclasses.dataclass(frozen=True)
class RuleMeta:
    id: str
    title: str
    attack: str
    severity: str
    why: str
    next_steps: str
    tuning: str


# Helper constants used by rules
LOCAL_IPS = {"127.0.0.1", "::1", "-", ""}


def _is_service_or_machine_account(user: str) -> bool:
    """
    Reduce false positives:
    - machine accounts often end with $
    - some environments prefix service accounts with svc*
    """
    u = (user or "").strip()
    if not u:
        return False
    if u.endswith("$"):
        return True
    lu = lower(u)
    return lu in {"system", "local system", "localsystem"} or lu.startswith("svc") or lu.startswith("service")


# -----------------------------
# Lateral movement matchers
# -----------------------------
def m_lm_rdp(e: NormEvent) -> bool:
    """
    4624 LogonType 10 is RemoteInteractive (RDP).
    """
    if e.event_id != "4624":
        return False
    if safe_str(e.extras.get("LogonType")) != "10":
        return False
    if e.src_ip in LOCAL_IPS:
        return False
    if _is_service_or_machine_account(e.user):
        return False
    return True


def m_lm_smb_ntlm(e: NormEvent) -> bool:
    """
    4624 LogonType 3 + NTLM is often SMB/WMI/service movement (noisy).
    """
    if e.event_id != "4624":
        return False
    if safe_str(e.extras.get("LogonType")) != "3":
        return False
    ap = lower(safe_str(e.extras.get("AuthPackage")))
    if "ntlm" not in ap:
        return False
    if e.src_ip in LOCAL_IPS:
        return False
    if _is_service_or_machine_account(e.user):
        return False
    return True


def m_lm_explicit_creds_4648(e: NormEvent) -> bool:
    """
    Event 4648 occurs when explicit creds are used (runas, remote auth, etc.).
    """
    return e.event_id == "4648" and not _is_service_or_machine_account(e.user)


def m_lm_psexec_7045(e: NormEvent) -> bool:
    """
    Event 7045 = service created.
    PsExec often uses PSEXESVC or UNC paths.
    """
    if e.event_id != "7045":
        return False
    svc = lower(safe_str(e.extras.get("ServiceName")))
    path = lower(safe_str(e.extras.get("ServicePath")))
    if "psexesvc" in svc or "psexec" in svc:
        return True
    if path.startswith("\\\\") or "\\\\" in path:
        return True
    return False


# -----------------------------
# Privilege escalation matchers
# -----------------------------
def m_pe_special_privs_4672(e: NormEvent) -> bool:
    """
    4672 = special privileges assigned to new logon.
    """
    return e.event_id == "4672" and not _is_service_or_machine_account(e.user)


def m_pe_admin_group_add(e: NormEvent) -> bool:
    """
    Group membership changes:
      4728 / 4732 / 4756
    We check GroupName text for admin-like keywords.
    """
    if e.event_id not in {"4728", "4732", "4756"}:
        return False
    ed = e.raw.get("EventData", {}) if isinstance(e.raw.get("EventData"), dict) else {}
    group = lower(safe_str(ed.get("GroupName") or ed.get("Group") or ""))
    if not group:
        return False
    keywords = ("admin", "administrators", "domain admins", "enterprise admins", "remote desktop users")
    return any(k in group for k in keywords)


# -----------------------------
# LOLBin matchers
# -----------------------------
def m_lol_powershell(e: NormEvent) -> bool:
    p = lower(e.process)
    c = lower(e.cmdline)
    return ("powershell" in p) or ("powershell" in c) or ("pwsh" in p)


def m_lol_powershell_encoded(e: NormEvent) -> bool:
    if "powershell" not in lower(e.process) and "powershell" not in lower(e.cmdline):
        return False
    lc = lower(e.cmdline)
    return ("-enc" in lc) or ("encodedcommand" in lc)


def m_lol_rundll32(e: NormEvent) -> bool:
    return lower(e.process).endswith("rundll32.exe")


def m_lol_regsvr32(e: NormEvent) -> bool:
    return lower(e.process).endswith("regsvr32.exe")


def m_lol_mshta(e: NormEvent) -> bool:
    return lower(e.process).endswith("mshta.exe")


def m_lol_certutil_download(e: NormEvent) -> bool:
    if not lower(e.process).endswith("certutil.exe"):
        return False
    lc = lower(e.cmdline)
    return "-urlcache" in lc or "http" in lc or "https" in lc


def m_lol_bitsadmin(e: NormEvent) -> bool:
    return lower(e.process).endswith("bitsadmin.exe")


def m_lol_wmic_process_create(e: NormEvent) -> bool:
    if not lower(e.process).endswith("wmic.exe"):
        return False
    lc = lower(e.cmdline)
    return "process" in lc and "call" in lc and "create" in lc


# -----------------------------
# Suspicious commandline matcher
# -----------------------------
def m_susp_obfuscated_cmd(e: NormEvent) -> bool:
    """
    Looks for base64 blobs or heavy obfuscation markers.
    """
    if not e.cmdline:
        return False
    lc = lower(e.cmdline)
    return e.extras.get("has_base64_blob") is True or any(k in lc for k in ("frombase64string", "encodedcommand", "iex", "invoke-expression"))


# =============================================================================
# Correlation (process chains)
# =============================================================================
@dataclasses.dataclass
class ProcNode:
    ts: str
    dt: Optional[dt.datetime]
    host: str
    process: str
    cmdline: str
    parent: str
    guid: str
    parent_guid: str
    user: str


def is_susp_chain(child: ProcNode) -> bool:
    """
    Simple heuristic:
      Office -> script/LOLBin
      PowerShell -> proxy exec (rundll32/regsvr32/mshta)
    """
    p = lower(child.process)
    pp = lower(child.parent)

    if any(x in pp for x in ("winword.exe", "excel.exe", "powerpnt.exe", "outlook.exe")) and any(
        x in p for x in ("powershell.exe", "wscript.exe", "cscript.exe", "mshta.exe")
    ):
        return True

    if ("powershell.exe" in pp) and any(x in p for x in ("rundll32.exe", "regsvr32.exe", "mshta.exe")):
        return True

    return False


@dataclasses.dataclass
class Correlator:
    """
    Rolling cache of recent process nodes.
    - by_guid enables linking to parent by ParentProcessGuid.
    - window is used for eviction to keep memory bounded.
    """
    max_per_host: int = 5000
    window: Deque[ProcNode] = dataclasses.field(default_factory=deque)
    by_guid: Dict[str, ProcNode] = dataclasses.field(default_factory=dict)

    def add(self, e: NormEvent) -> Optional[ProcNode]:
        # Only meaningful for process creation events
        if e.event_id not in {"1", "4688"}:
            return None

        node = ProcNode(
            ts=e.ts,
            dt=e.dt,
            host=e.host,
            process=e.process,
            cmdline=e.cmdline,
            parent=e.parent_process,
            guid=safe_str(e.extras.get("ProcessGuid")),
            parent_guid=safe_str(e.extras.get("ParentProcessGuid")),
            user=e.user,
        )

        if node.guid:
            self.by_guid[node.guid] = node

        self.window.append(node)

        # Evict old nodes to prevent memory blowups on huge logs
        if len(self.window) > self.max_per_host:
            old = self.window.popleft()
            if old.guid:
                self.by_guid.pop(old.guid, None)

        return node


