# =============================================================================
# Config + allowlists
# =============================================================================
def load_config(path: str) -> Dict[str, Any]:
    """
    Load YAML (if available) or JSON config.
    """
    p = Path(path)
    if not p.exists():
        raise FileNotFoundError(path)

    text = p.read_text(encoding="utf-8", errors="ignore")

    if p.suffix.lower() in {".yml", ".yaml"} and YAML_AVAILABLE and yaml is not None:
        data = yaml.safe_load(text)  # type: ignore
        return data if isinstance(data, dict) else {}

    return json.loads(text)


def load_lines_file(path: str) -> List[str]:
    """
    Read allowlist file (one entry per line).
    Supports comments with #.
    """
    p = Path(path)
    if not p.exists():
        return []
    lines = []
    for line in p.read_text(encoding="utf-8", errors="ignore").splitlines():
        s = line.strip()
        if not s or s.startswith("#"):
            continue
        lines.append(s)
    return lines


def is_allowlisted_user(user: str, allow_users: Sequence[str]) -> bool:
    u = lower(user).strip()
    if not u:
        return False
    return any(u == lower(x).strip() for x in allow_users)


def is_allowlisted_ip(ip: str, allow_ips: Sequence[str]) -> bool:
    s = (ip or "").strip()
    if not s:
        return False
    return any(s == (x or "").strip() for x in allow_ips)


# =============================================================================
# Baseline model (simple but very effective)
# =============================================================================
@dataclasses.dataclass
class Baseline:
    """
    Baseline tracks what is 'normal' (very small/simple baseline).
    Useful for prioritizing anomalies like "new src_ip for user".
    """
    user_src_ips: Dict[str, Counter] = dataclasses.field(default_factory=lambda: defaultdict(Counter))

    def observe(self, e: NormEvent) -> None:
        u = lower(e.user).strip()
        ip = (e.src_ip or "").strip()
        if u and ip and ip not in LOCAL_IPS:
            self.user_src_ips[u][ip] += 1

    def is_new_src_for_user(self, user: str, src_ip: str, min_seen: int = 1) -> bool:
        u = lower(user).strip()
        ip = (src_ip or "").strip()
        if not u or not ip:
            return False
        return self.user_src_ips[u][ip] < min_seen


# =============================================================================
# Sources
# =============================================================================
@dataclasses.dataclass
class EvtxSource:
    """
    A wrapper around an EVTX path that yields NormEvents.
    """
    path: str
    source_hint: str = "windows_evtx"

    def iter_events(self, progress: bool = False) -> Iterable[NormEvent]:
        it = iter_evtx_records(self.path)

        # Optional progress bar
        if progress and TQDM_AVAILABLE and tqdm is not None:
            it = tqdm(it, desc=f"EVTX {Path(self.path).name}", unit="ev")  # type: ignore

        for rec in it:
            yield normalize_event(rec, self.source_hint)


def autodiscover_evtx() -> List[str]:
    """
    Default Windows EVTX auto-discovery.
    """
    if os.name != "nt":
        return []

    base = Path(os.environ.get("SystemRoot", r"C:\Windows")) / "System32" / "winevt" / "Logs"
    candidates = [
        base / "Security.evtx",
        base / "Microsoft-Windows-Sysmon%4Operational.evtx",
    ]
    return [str(p) for p in candidates if p.exists()]


# =============================================================================
# Hunt engine
# =============================================================================
def within_time(e: NormEvent, since: Optional[dt.datetime], until: Optional[dt.datetime]) -> bool:
    """
    If event dt is missing, we do NOT drop it.
    Time filter only applies if dt is available.
    """
    if e.dt is None:
        return True
    if since and e.dt < since:
        return False
    if until and e.dt > until:
        return False
    return True


def make_finding(meta: RuleMeta, e: NormEvent, note: str = "", confidence: str = "medium") -> Dict[str, Any]:
    """
    Convert a matched rule into a structured finding for output.
    """
    return {
        "ts": e.ts,
        "rule_id": meta.id,
        "title": meta.title,
        "attack": meta.attack,
        "severity": meta.severity,
        "confidence": confidence,
        "note": note,
        "host": e.host,
        "user": e.user,
        "src_ip": e.src_ip,
        "process": e.process,
        "cmdline": e.cmdline,
        "enrichment": {
            "ip_private": e.extras.get("ip_private"),
            "urls": e.extras.get("urls"),
            "has_base64_blob": e.extras.get("has_base64_blob"),
            "susp_flags": e.extras.get("susp_flags"),
            "LogonType": e.extras.get("LogonType"),
            "AuthPackage": e.extras.get("AuthPackage"),
            "WorkstationName": e.extras.get("WorkstationName"),
        },
        "triage": {
            "why": meta.why,
            "next_steps": meta.next_steps,
            "tuning": meta.tuning,
        },
        "event": dataclasses.asdict(e),
    }


def hunt_sources(
    sources: List[EvtxSource],
    since: Optional[dt.datetime],
    until: Optional[dt.datetime],
    enabled_rule_ids: Optional[set],
    disabled_rule_ids: Optional[set],
    baseline: Optional[Baseline],
    allow_users: Sequence[str],
    allow_ips: Sequence[str],
    progress: bool,
) -> List[Dict[str, Any]]:
    """
    Main hunt pipeline:
    - iterate events
    - apply filters
    - run correlation heuristics
    - run rules
    - collect findings
    """
    findings: List[Dict[str, Any]] = []
    corr = Correlator()

    enabled_rule_ids = enabled_rule_ids or set()
    disabled_rule_ids = disabled_rule_ids or set()

    # Determine which rules to run
    rules_to_run: List[Tuple[RuleMeta, Callable[[NormEvent], bool]]] = []
    for meta, fn in RULES:
        if meta.id in disabled_rule_ids:
            continue
        if enabled_rule_ids and meta.id not in enabled_rule_ids:
            continue
        rules_to_run.append((meta, fn))

    # Iterate each EVTX file
    for src in sources:
        log.info("Processing %s", src.path)

        for e in src.iter_events(progress=progress):
            # Time filter (best-effort)
            if not within_time(e, since, until):
                continue

            # Allowlists (reduce known-good noise)
            if is_allowlisted_user(e.user, allow_users):
                continue
            if is_allowlisted_ip(e.src_ip, allow_ips):
                continue

            # Baseline anomaly notes (adds triage value)
            baseline_note = ""
            confidence = "medium"

            if baseline is not None:
                if e.event_id == "4624" and e.user and e.src_ip and e.src_ip not in LOCAL_IPS:
                    if baseline.is_new_src_for_user(e.user, e.src_ip, min_seen=1):
                        baseline_note = "Baseline: NEW source IP for this user"
                        confidence = "high"

            # Correlation: process chain heuristic
            node = corr.add(e)
            if node and is_susp_chain(node):
                findings.append({
                    "ts": e.ts,
                    "rule_id": "CORR-SUSP-PROC-CHAIN",
                    "title": "Suspicious process chain (parent/child heuristic)",
                    "attack": "T1204/T1059/T1218",
                    "severity": "high",
                    "confidence": "high",
                    "note": "Heuristic chain match (Office -> script/LOLBin, or PowerShell -> proxy exec).",
                    "host": e.host,
                    "user": e.user,
                    "src_ip": e.src_ip,
                    "process": e.process,
                    "cmdline": e.cmdline,
                    "enrichment": {"parent": node.parent, "urls": e.extras.get("urls"), "susp_flags": e.extras.get("susp_flags")},
                    "triage": {
                        "why": "Attackers frequently chain signed binaries and scripts from user applications.",
                        "next_steps": "Review parent process, file origin, email/download context; pivot to network/file events.",
                        "tuning": "Baseline common Office add-ins and admin scripts; require URLs or suspicious flags for higher confidence.",
                    },
                    "event": dataclasses.asdict(e),
                })

            # Run detection rules
            for meta, fn in rules_to_run:
                try:
                    if fn(e):
                        findings.append(make_finding(meta, e, note=baseline_note, confidence=confidence))
                except Exception:
                    # Never let a single rule break the pipeline
                    continue

    return findings


# =============================================================================
# Output
# =============================================================================
def write_json(path: str, findings: List[Dict[str, Any]]) -> None:
    Path(path).write_text(json.dumps(findings, indent=2, ensure_ascii=False), encoding="utf-8")


def write_jsonl(path: str, findings: List[Dict[str, Any]]) -> None:
    with open(path, "w", encoding="utf-8") as f:
        for item in findings:
            f.write(json.dumps(item, ensure_ascii=False) + "\n")


def write_csv(path: str, findings: List[Dict[str, Any]]) -> None:
    if not findings:
        return
    fieldnames = ["ts", "rule_id", "title", "attack", "severity", "confidence", "host", "user", "src_ip", "process", "cmdline", "note"]
    with open(path, "w", encoding="utf-8", newline="") as out:
        w = csv.DictWriter(out, fieldnames=fieldnames)
        w.writeheader()
        for fnd in findings:
            row = {k: fnd.get(k, "") for k in fieldnames}
            # prevent insanely long CSV cells
            row["cmdline"] = (row.get("cmdline") or "")[:4000]
            w.writerow(row)


def print_summary(findings: List[Dict[str, Any]]) -> None:
    if not findings:
        print("No detections fired.")
        return

    by_rule = Counter(f["rule_id"] for f in findings)
    by_sev = Counter(f.get("severity", "unknown") for f in findings)
    by_user = Counter(f.get("user", "") for f in findings if f.get("user"))
    by_ip = Counter(f.get("src_ip", "") for f in findings if f.get("src_ip"))

    print("\n=== Summary ===")
    print("Rules:")
    for rid, c in by_rule.most_common(15):
        print(f"  {rid:<24} {c}")

    print("\nSeverity:")
    for sev, c in by_sev.most_common():
        print(f"  {sev:<8} {c}")

    if by_user:
        print("\nTop users:")
        print("  " + ", ".join(f"{u} ({c})" for u, c in by_user.most_common(8)))

    if by_ip:
        print("\nTop source IPs:")
        print("  " + ", ".join(f"{ip} ({c})" for ip, c in by_ip.most_common(8)))

    print("\nTop findings:")
    for fnd in findings[:10]:
        print(f"- {fnd['ts']} | {fnd['severity']} | {fnd['rule_id']} | {fnd['title']}")
        print(f"  host={fnd.get('host','')} user={fnd.get('user','')} src_ip={fnd.get('src_ip','')}")
        if fnd.get("note"):
            print(f"  note={fnd['note']}")
        if fnd.get("process"):
            print(f"  proc={fnd.get('process','')}")
        print("")


# =============================================================================
# Self test
# =============================================================================
def run_selftest() -> int:
    """
    Minimal deterministic tests so recruiters see you care about correctness.
    """
    now = dt.datetime(2025, 12, 12, 12, 0, 0, tzinfo=dt.timezone.utc)

    e_rdp = NormEvent(
        ts="2025-12-12T12:00:00Z",
        dt=now,
        event_id="4624",
        user="derek",
        src_ip="10.9.8.7",
        host="WINHOST",
        extras={"LogonType": "10", "AuthPackage": "Negotiate"},
        raw={"EventData": {"LogonType": "10"}},
    )
    enrich_event(e_rdp)
    assert m_lm_rdp(e_rdp) is True

    e_ps = NormEvent(
        ts="2025-12-12T12:01:00Z",
        dt=now,
        event_id="1",
        user="derek",
        host="WINHOST",
        process=r"C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe",
        cmdline="powershell.exe -enc AAAABBBBCCCC",
        parent_process=r"C:\Program Files\Microsoft Office\root\Office16\WINWORD.EXE",
        extras={"ProcessGuid": "{111}", "ParentProcessGuid": "{222}"},
    )
    enrich_event(e_ps)
    assert m_lol_powershell_encoded(e_ps) is True
    assert m_susp_obfuscated_cmd(e_ps) is True

    node = ProcNode(
        ts=e_ps.ts, dt=e_ps.dt, host=e_ps.host,
        process=e_ps.process, cmdline=e_ps.cmdline,
        parent=e_ps.parent_process, guid="{111}",
        parent_guid="{222}", user=e_ps.user
    )
    assert is_susp_chain(node) is True

    print("[+] Selftest passed.")
    return EXIT_OK


# =============================================================================
# CLI
# =============================================================================
def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        description="ELHE — Enterprise Log Hunt Engine (single-file)",
        epilog="Run with no args for auto-discovery (Windows). Use --logs to specify EVTX paths.",
    )
    p.add_argument("--logs", nargs="+", help="EVTX log paths")
    p.add_argument("--config", help="Config file (.yml/.yaml/.json). CLI args override config.")
    p.add_argument("--since", help="ISO timestamp, e.g. 2025-12-01T00:00:00Z")
    p.add_argument("--until", help="ISO timestamp")
    p.add_argument("--baseline", action="store_true", help="Enable baseline/anomaly notes (two-pass scan).")
    p.add_argument("--allow-users", help="File with allowlisted usernames (one per line).")
    p.add_argument("--allow-ips", help="File with allowlisted source IPs (one per line).")
    p.add_argument("--enable-rules", nargs="+", help="Only run these rule IDs.")
    p.add_argument("--disable-rules", nargs="+", help="Disable these rule IDs.")
    p.add_argument("--list-rules", action="store_true", help="List rule IDs and exit.")
    p.add_argument("--out", help="Write findings to file.")
    p.add_argument("--format", choices=["json", "jsonl", "csv"], default="json", help="Output format for --out")
    p.add_argument("--progress", action="store_true", help="Show progress bar (tqdm).")
    p.add_argument("--verbose", action="store_true")
    p.add_argument("--quiet", action="store_true")
    p.add_argument("--selftest", action="store_true", help="Run built-in tests and exit.")
    return p


def merge_config(cli: argparse.Namespace, cfg: Dict[str, Any]) -> argparse.Namespace:
    """
    Simple config merge:
    - If CLI value is missing/default, fill from config.
    - If CLI provided it, keep CLI.
    """
    for k, v in cfg.items():
        name = k.replace("-", "_")
        if not hasattr(cli, name):
            continue
        cur = getattr(cli, name)
        if cur is None or cur == [] or cur is False:
            setattr(cli, name, v)
    return cli


def load_config_if_present(args: argparse.Namespace) -> argparse.Namespace:
    if not args.config:
        return args
    try:
        cfg = load_config(args.config)
        return merge_config(args, cfg)
    except Exception as e:
        print(f"[!] Failed to load config: {e}")
        raise


def main(argv: Optional[List[str]] = None) -> int:
    args = build_parser().parse_args(argv)
    setup_logging(args.verbose, args.quiet)

    # Selftest is a fast sanity check
    if args.selftest:
        return run_selftest()

    # Rule listing is useful for users and documentation
    if args.list_rules:
        for meta, _ in RULES:
            print(f"{meta.id}  [{meta.severity}]  {meta.title}  ({meta.attack})")
        print("\nAlso: CORR-SUSP-PROC-CHAIN (correlation heuristic)")
        return EXIT_OK

    # Config file support (optional)
    try:
        args = load_config_if_present(args)
    except Exception:
        return EXIT_FATAL

    # Determine log paths:
    # - CLI --logs if provided
    # - else auto-discovery (Windows)
    logs = args.logs or autodiscover_evtx()

    if not logs:
        print("[!] No logs found/provided.")
        print(r'    Example: python Chap10.py --logs "C:\Windows\System32\winevt\Logs\Security.evtx"')
        return EXIT_NO_LOGS

    # EVTX parsing dependency check
    if not EVTX_AVAILABLE:
        print("[!] Missing dependency: python-evtx")
        print("    Install: pip install python-evtx")
        return EXIT_DEP_MISSING

    # Time filters
    since_dt = parse_user_time(args.since) if args.since else None
    until_dt = parse_user_time(args.until) if args.until else None

    # Allowlists
    allow_users = load_lines_file(args.allow_users) if args.allow_users else []
    allow_ips = load_lines_file(args.allow_ips) if args.allow_ips else []

    # Rule enable/disable
    enabled = set(args.enable_rules or [])
    disabled = set(args.disable_rules or [])

    # Build sources (existing files only)
    sources: List[EvtxSource] = []
    for pth in logs:
        if Path(pth).exists():
            sources.append(EvtxSource(path=pth, source_hint="windows_evtx"))
        else:
            log.warning("Log not found: %s", pth)

    if not sources:
        print("[!] None of the provided logs exist.")
        return EXIT_NO_LOGS

    # Baseline pass (optional)
    baseline_obj: Optional[Baseline] = None
    if args.baseline:
        baseline_obj = Baseline()
        log.info("Baseline enabled: first pass building baseline model...")
        for src in sources:
            for e in src.iter_events(progress=args.progress):
                if not within_time(e, since_dt, until_dt):
                    continue
                if is_allowlisted_user(e.user, allow_users) or is_allowlisted_ip(e.src_ip, allow_ips):
                    continue
                baseline_obj.observe(e)

    # Hunting pass
    log.info("Hunting %d EVTX file(s)...", len(sources))
    findings = hunt_sources(
        sources=sources,
        since=since_dt,
        until=until_dt,
        enabled_rule_ids=enabled if enabled else None,
        disabled_rule_ids=disabled if disabled else None,
        baseline=baseline_obj,
        allow_users=allow_users,
        allow_ips=allow_ips,
        progress=args.progress,
    )

    # Print summary to console
    print_summary(findings)

    # Optional file output
    if args.out:
        try:
            if args.format == "json":
                write_json(args.out, findings)
            elif args.format == "jsonl":
                write_jsonl(args.out, findings)
            else:
                write_csv(args.out, findings)
            print(f"[+] Wrote {len(findings)} findings -> {args.out} ({args.format})")
        except Exception as e:
            print(f"[!] Failed to write output: {e}")
            return EXIT_FATAL

    # Friendly guidance if nothing fired
    if not findings:
        print("\n[i] Tip: If you expected results, try:")
        print("    - Enable Sysmon and ensure Sysmon Operational EVTX is present")
        print("    - Run with --baseline to prioritize NEW sources for users")
        print("    - Provide a wider window (--since/--until)")

    return EXIT_OK


if __name__ == "__main__":
    raise SystemExit(main())
