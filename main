            why="Can proxy execution in suspicious patterns.",
            next_steps="Inspect cmdline for scriptlet/network references and parent process.",
            tuning="Allowlist specific installers if required; focus on URLs.",
        ),
        m_lol_regsvr32,
    ),
    (
        RuleMeta(
            id="LOL-MSHTA",
            title="mshta execution (LOLBin)",
            attack="T1218.005",
            severity="high",
            why="Common for script execution and remote payload staging.",
            next_steps="Inspect URLs and file writes; check parent process (Office) and network activity.",
            tuning="Often suspicious in enterprises; allowlist only known legacy apps.",
        ),
        m_lol_mshta,
    ),
    (
        RuleMeta(
            id="LOL-CERTUTIL-DL",
            title="certutil used for download/staging",
            attack="T1105",
            severity="high",
            why="certutil can fetch remote content and is a common staging tool.",
            next_steps="Extract URL + destination; correlate with execution shortly after.",
            tuning="Allowlist only if you truly have legitimate certutil download workflows.",
        ),
        m_lol_certutil_download,
    ),
    (
