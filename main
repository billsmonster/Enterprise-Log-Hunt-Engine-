            next_steps="Look for encoded commands, suspicious parents (Office/WMI/services), and outbound connections (Sysmon 3).",
            tuning="Baseline admin scripts; focus on rare parents + suspicious flags.",
        ),
        m_lol_powershell,
    ),
    (
        RuleMeta(
            id="LOL-POWERSHELL-ENC",
            title="PowerShell encoded/obfuscated command",
            attack="T1027",
            severity="high",
            why="Encoded commands are strongly associated with malicious execution and evasion.",
            next_steps="Decode payload safely; extract IOCs; correlate with network + file writes.",
            tuning="Rarely benign; allowlist only trusted tooling if necessary.",
        ),
        m_lol_powershell_encoded,
    ),
    (
        RuleMeta(
            id="LOL-RUNDLL32",
            title="rundll32 execution (LOLBin)",
            attack="T1218.011",
            severity="medium",
            why="Signed proxy execution technique frequently used in malware chains.",
            next_steps="Inspect DLL path/exports; look for URL/UNC patterns; check parent.",
